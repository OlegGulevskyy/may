rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function supportedMediaUpload() {
      return request.resource != null
        && request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches("(image|video|audio)/.*");
    }

    // Storage rules can only read the default Firestore database through
    // firestore.exists(). App data lives in the named may-default database, so
    // membership remains enforced by Firestore while Storage gates signed-in
    // media access and basic upload shape here.
    match /families/{familyId}/posts/{postId}/media/{mediaId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && supportedMediaUpload();
    }

    match /families/{familyId}/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
