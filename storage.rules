rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function familyMember(familyId) {
      return signedIn()
        && firestore.exists(/databases/may-default/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    match /families/{familyId}/{allPaths=**} {
      allow read, write: if familyMember(familyId);
    }
  }
}
