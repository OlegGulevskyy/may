{
  "expo": {
    "extra": {
      "eas": {
        "projectId": "7a7a9b53-58b0-4d92-8499-a0559eeff350"
      }
    },
    "name": "Dinomay",
    "slug": "may",
    "version": "1.0.0",
    "scheme": "dinomay",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oleggulevskyy.may",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.oleggulevskyy.may",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Dinomay needs photo access so you can send memories from your library.",
          "cameraPermission": "Dinomay needs camera access so you can capture memories inside the app.",
          "microphonePermission": "Dinomay needs microphone access so videos can include sound."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Dinomay needs microphone access so you can record voice notes.",
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ]
  }
}
