{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "ignoreDeprecations": "6.0",
    "module": "Node16",
    "moduleResolution": "Node16",
    "noEmit": false,
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["src"]
}
