{
  "name": "functions",
  "version": "0.0.0",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf lib",
    "deploy": "pnpm dlx firebase-tools deploy --only functions",
    "dev": "JAVA_HOME=$(/usr/libexec/java_home -v 21); PATH=\"$JAVA_HOME/bin:$PATH\" pnpm dlx firebase-tools emulators:start --only functions,firestore,storage",
    "dev:clear-db": "node scripts/dev-firestore.js clear-db",
    "dev:check-db": "node scripts/dev-firestore.js check",
    "dev:seed-wall": "node scripts/dev-firestore.js seed-wall"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-email": "^6.6.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "~19.2.17",
    "typescript": "6.0.3"
  }
}
