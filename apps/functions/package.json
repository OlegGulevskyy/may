    "node": ">=22"
  },
  "dependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "6.0.3"
  }
}
