rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function familyMember(familyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    match /inviteCodes/{code} {
      allow create: if signedIn()
        && request.resource.data.code == code
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "pending";
      allow get: if signedIn() && resource.data.status == "pending";
      allow list: if false;
      allow update: if signedIn()
        && request.resource.data.code == resource.data.code
        && request.resource.data.familyId == resource.data.familyId
        && resource.data.status == "pending"
        && request.resource.data.status == "accepted"
        && request.resource.data.acceptedBy == request.auth.uid;
      allow delete: if false;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /families/{familyId} {
      allow create: if signedIn();
      allow read: if familyMember(familyId);
      allow update, delete: if false;

      match /members/{memberId} {
        allow read: if familyMember(familyId);
        allow create, update: if signedIn() && request.auth.uid == memberId;
        allow delete: if false;
      }

      match /invites/{inviteCode} {
        allow read: if familyMember(familyId);
        allow create: if familyMember(familyId)
          && request.resource.data.code == inviteCode
          && request.resource.data.status == "pending";
        allow update: if familyMember(familyId)
          || (
            signedIn()
            && request.resource.data.code == resource.data.code
            && request.resource.data.familyId == resource.data.familyId
            && resource.data.code == inviteCode
            && resource.data.status == "pending"
            && request.resource.data.status == "accepted"
            && request.resource.data.acceptedBy == request.auth.uid
          );
        allow delete: if false;
      }

      match /deliveryGrantRequests/{requestId} {
        allow create: if familyMember(familyId)
          && request.resource.data.keys().hasOnly([
            "createdAt",
            "createdBy",
            "familyId",
            "googleEmail",
            "serverAuthCode"
          ])
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.familyId == familyId
          && request.resource.data.createdAt is string
          && request.resource.data.googleEmail is string
          && request.resource.data.serverAuthCode is string;
        allow read, update, delete: if false;
      }

      match /private/{privateDocId} {
        allow read, write: if false;
      }

      match /posts/{postId} {
        allow read, create, update: if familyMember(familyId);
        allow delete: if false;

        match /media/{mediaId} {
          allow read, create, update: if familyMember(familyId);
          allow delete: if false;
        }

        match /comments/{commentId} {
          allow read, create, update: if familyMember(familyId);
          allow delete: if false;
        }
      }
    }
  }
}
