rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function familyMember(familyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function validFamilyDeliveryCcEmails() {
      return !request.resource.data.keys().hasAny(["deliveryCcEmails"])
        || (
          request.resource.data.deliveryCcEmails is list
          && request.resource.data.deliveryCcEmails.size() <= 10
          && validDeliveryCcEmailAt(0)
          && validDeliveryCcEmailAt(1)
          && validDeliveryCcEmailAt(2)
          && validDeliveryCcEmailAt(3)
          && validDeliveryCcEmailAt(4)
          && validDeliveryCcEmailAt(5)
          && validDeliveryCcEmailAt(6)
          && validDeliveryCcEmailAt(7)
          && validDeliveryCcEmailAt(8)
          && validDeliveryCcEmailAt(9)
        );
    }

    function validDeliveryCcEmailAt(index) {
      return request.resource.data.deliveryCcEmails.size() <= index
        || (
          request.resource.data.deliveryCcEmails[index] is string
          && request.resource.data.deliveryCcEmails[index].size() <= 320
        );
    }

    function validPushTokenDocument(familyId, memberId) {
      return request.resource.data.keys().hasOnly([
          "createdAt",
          "familyId",
          "memberId",
          "platform",
          "token",
          "tokenType",
          "updatedAt"
        ])
        && request.resource.data.familyId == familyId
        && request.resource.data.memberId == memberId
        && request.resource.data.token is string
        && request.resource.data.token.size() <= 512
        && request.resource.data.tokenType == "expo"
        && request.resource.data.platform in ["android", "ios", "web"]
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    match /inviteCodes/{code} {
      allow create: if signedIn()
        && request.resource.data.code == code
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "pending";
      allow get: if signedIn() && resource.data.status == "pending";
      allow list: if false;
      allow update: if signedIn()
        && request.resource.data.code == resource.data.code
        && request.resource.data.familyId == resource.data.familyId
        && resource.data.status == "pending"
        && request.resource.data.status == "accepted"
        && request.resource.data.acceptedBy == request.auth.uid;
      allow delete: if false;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;

      match /families/{familyId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create, update: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.familyId == familyId
          && request.resource.data.memberId == request.auth.uid;
        allow delete: if false;
      }
    }

    match /families/{familyId} {
      allow create: if signedIn();
      allow read: if familyMember(familyId);
      allow update: if familyMember(familyId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "deliveryCcEmail",
          "deliveryCcEmails",
          "updatedAt"
        ])
        && !request.resource.data.keys().hasAny(["deliveryCcEmail"])
        && request.resource.data.updatedAt is string
        && validFamilyDeliveryCcEmails();
      allow delete: if false;

      match /members/{memberId} {
        allow read: if familyMember(familyId)
          || (signedIn() && request.auth.uid == memberId);
        allow create: if signedIn()
          && request.auth.uid == memberId
          && !request.resource.data.keys().hasAny(["deliveryConnection"]);
        allow update: if signedIn()
          && request.auth.uid == memberId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["deliveryConnection"]);
        allow delete: if false;

        match /pushTokens/{tokenId} {
          allow read: if false;
          allow create, update: if signedIn()
            && request.auth.uid == memberId
            && familyMember(familyId)
            && validPushTokenDocument(familyId, memberId);
          allow delete: if signedIn()
            && request.auth.uid == memberId
            && resource.data.familyId == familyId
            && resource.data.memberId == memberId;
        }
      }

      match /invites/{inviteCode} {
        allow read: if familyMember(familyId);
        allow create: if familyMember(familyId)
          && request.resource.data.code == inviteCode
          && request.resource.data.status == "pending";
        allow update: if familyMember(familyId)
          || (
            signedIn()
            && request.resource.data.code == resource.data.code
            && request.resource.data.familyId == resource.data.familyId
            && resource.data.code == inviteCode
            && resource.data.status == "pending"
            && request.resource.data.status == "accepted"
            && request.resource.data.acceptedBy == request.auth.uid
          );
        allow delete: if false;
      }

      match /deliveryGrantRequests/{requestId} {
        allow create: if familyMember(familyId)
          && request.resource.data.keys().hasOnly([
            "createdAt",
            "createdBy",
            "familyId",
            "googleEmail",
            "serverAuthCode"
          ])
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.familyId == familyId
          && request.resource.data.createdAt is string
          && request.resource.data.googleEmail is string
          && request.resource.data.serverAuthCode is string;
        allow read, update, delete: if false;
      }

      match /private/{privateDocId} {
        allow read, write: if false;

        match /{document=**} {
          allow read, write: if false;
        }
      }

      match /posts/{postId} {
        allow read, create, update: if familyMember(familyId);
        allow delete: if false;

        match /media/{mediaId} {
          allow read, create, update: if familyMember(familyId);
          allow delete: if false;
        }

        match /comments/{commentId} {
          allow read, create, update: if familyMember(familyId);
          allow delete: if false;
        }
      }
    }
  }
}
