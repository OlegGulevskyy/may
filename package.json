{
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=!functions",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "deploy:fns": "pnpm --filter functions build && pnpm dlx firebase-tools deploy --only functions",
    "submit:ios": "cd apps/native && eas submit --platform ios",
    "firebase:reauth": "pnpm dlx firebase-tools login --reauth",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "turbo": "^2.9.18"
  },
  "engines": {
    "node": ">=18"
  },
  "name": "may",
  "packageManager": "pnpm@11.5.2"
}
